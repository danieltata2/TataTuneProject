<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:id="@+id/scrollPrincipal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/miniPlayerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp"
                android:paddingHorizontal="22dp"
                android:paddingTop="10dp">

                <ImageView
                    android:id="@+id/btnVolver"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_icon_button"
                    android:padding="9dp"
                    android:src="@drawable/ic_back" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="22dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.18"
                    android:text="@string/lista_anadir"
                    android:textColor="#FF6B35"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.1"
                    android:text="@string/lista_titulo_pl"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="#1C1C1F"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:paddingHorizontal="14dp">
                        <SearchView
                            android:id="@+id/buscador"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:iconifiedByDefault="false"
                            android:queryHint="@string/lista_buscar" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="2dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/chipTodas"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_active"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="@string/lista_todas"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/chipRecientes"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_inactive"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="@string/lista_recientes"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/chipFavoritas"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_inactive"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="@string/lista_favoritas"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="14dp"
                android:background="#1E1E22" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="22dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14"
                    android:text="@string/lista_bl"
                    android:textColor="@color/text_primary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtContador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lista_ncanciones"
                    android:textColor="@color/text_primary"
                    android:textSize="10sp" />

            </LinearLayout>

            <ListView
                android:id="@+id/listaCancionesPlaylist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingHorizontal="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="24dp"
                android:scrollbars="none" />

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/miniPlayerContainer"
        layout="@layout/mini_player"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/menuInferior"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <include
        android:id="@+id/menuInferior"
        layout="@layout/menu_inferior"
        android:layout_width="0dp"
        android:layout_height="65dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>