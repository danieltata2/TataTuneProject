<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notifLayout"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/accent_orange"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/notifCover"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/notifTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/notifArtista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#BBBBBB"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/notifPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_previous"
            android:background="@null"
            app:tint="#FFFFFF"/>

        <ImageButton
            android:id="@+id/notifPlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_play"
            android:background="@null"
            app:tint="#FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <ImageButton
            android:id="@+id/notifNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_next"
            android:background="@null"
            app:tint="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>