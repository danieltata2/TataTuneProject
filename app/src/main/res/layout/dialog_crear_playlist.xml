<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="24dp">


    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="22dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pl_nuevo"
                android:textSize="10sp"
                android:letterSpacing="0.18"
                android:textColor="#FF6B35"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pl_crear"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="-0.02" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnCerrar"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_icon_button"
            android:padding="9dp" />

    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="22dp"
        android:paddingBottom="22dp">

        <FrameLayout
            android:id="@+id/btnElegirImagen"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/iconDefaultArtwork"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="8dp"
                >

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_music_note"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pl_foto"
                    android:textSize="10sp"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

        </FrameLayout>

        <Button
            android:id="@+id/btnTextoElegirImagen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pl_foto_elegir"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip_inactive"
            android:paddingHorizontal="18dp"
            android:paddingVertical="7dp" />

    </LinearLayout>


    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pl_nombre"
            android:textSize="10sp"
            android:letterSpacing="0.14"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:cardCornerRadius="13dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#222226">

            <EditText
                android:id="@+id/txtNombrePlaylist"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/pl_nombre_hint"
                android:textColor="#E0E0E8"
                android:textColorHint="#444444"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:background="@null"
                android:maxLength="40"
                android:inputType="textCapSentences"
                android:imeOptions="actionDone"
                android:singleLine="true" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <Button
        android:id="@+id/btnCrearPlaylist"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="22dp"
        android:layout_marginTop="22dp"
        android:text="@string/pl_crear"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/accent_orange"
        android:enabled="true"
        android:alpha="1"
        app:cornerRadius="14dp" />

</LinearLayout>